    "better-sqlite3": "^12.8.0",
    "discord-api-types": "^0.37.21",
    "discord.js": "^14.26.2",
    "dotenv": "^10.0.0",
    "ffmpeg-static": "^4.4.0",
    "googleapis": "^87.0.0",
    "libsodium-wrappers": "^0.7.9",
    "mongoose": "^6.0.5",
    "node-pre-gyp": "^0.17.0",
